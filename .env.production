# Production Environment Variables Template
# Copy this to .env for production deployment
# IMPORTANT: Never commit .env files with real values to Git!

# ==================== REQUIRED ====================
# Gemini API Key (Required for AI features)
GEMINI_API_KEY=AIzaSyCkoMhPZtejkRpPaOH3OCKuz1eHk2IFF9I

# ==================== OPTIONAL ====================
# External API Keys
OPENWEATHER_API_KEY=66a74419b020a4c7b5f148588bc9e756
NEWS_API_KEY=60b37be7a8a74224bb6c0c68c2dcfa8a

# OpenRouter API Configuration (Alternative AI provider)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=meta-llama/llama-3.2-3b-instruct:free

# ==================== BACKEND CONFIGURATION ====================
# Backend Server Settings
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Frontend URL (for CORS configuration)
# Update this to your production frontend URL
FRONTEND_URL=https://your-frontend-domain.com

# ==================== LLM CONFIGURATION ====================
# Mode: local (Ollama only), cloud (Gemini only), hybrid (smart routing)
LLM_MODE=cloud

# Ollama/Local LLM Configuration (if using local mode)
OLLAMA_BASE_URL=http://localhost:11434
LOCAL_MODEL=llama3.2:3b

# Multi-Model AI Configuration
ENABLE_MULTI_MODEL=false
USE_OPENROUTER_FALLBACK=true

# ==================== GOOGLE INTEGRATION ====================
# Google OAuth credentials file path (optional)
GOOGLE_CREDENTIALS_FILE=credentials.json

# ==================== SECURITY ====================
# Add any additional security settings here
# ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com
