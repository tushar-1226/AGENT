# API Keys (Keep these secure!)
GEMINI_API_KEY=your_gemini_api_key_here
OPENWEATHER_API_KEY=your_openweather_api_key_here
NEWS_API_KEY=your_news_api_key_here

# Backend Configuration
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:3000

# LLM Configuration
# Mode: local (Ollama only), cloud (Gemini only), hybrid (smart routing)
LLM_MODE=hybrid

# Ollama/Local LLM Configuration
OLLAMA_BASE_URL=http://localhost:11434
LOCAL_MODEL=qwen2.5-coder:7b

# Available Local Models (for reference)
# - qwen2.5-coder:7b    (Best for coding - 4.7GB) [RECOMMENDED]
# - llama3.2:3b         (Fast general-purpose - 2.0GB)
# - gemma2:9b           (Balanced performance - 5.4GB)
# - codellama:7b        (Code specialized - 3.8GB)
# - phi3:mini           (Efficient reasoning - 2.3GB)

# Google Integration
GOOGLE_CREDENTIALS_FILE=credentials.json

# OpenRouter API Configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=meta-llama/llama-3.2-3b-instruct:free

# Multi-Model AI Configuration
ENABLE_MULTI_MODEL=false  # Set to true to compare Gemini vs OpenRouter responses
USE_OPENROUTER_FALLBACK=true  # Use OpenRouter when Gemini fails
